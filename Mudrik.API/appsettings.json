{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "JwtSettings": {
    "SecretKey": "YOUR_SUPER_SECRET_KEY_MIN_32_CHARACTERS_LONG!",
    "Issuer": "CleanAuthApi",
    "Audience": "CleanAuthClients",
    "ExpiryMinutes": 60
  },
  "GoogleAuth": {
    "ClientId": "YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com"
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "con": "Data Source=.;Initial Catalog=Mudrik;Integrated Security=True;Trust Server Certificate=True"
  }
}
